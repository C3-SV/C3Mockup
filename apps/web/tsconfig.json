{
  "extends": "../../packages/config/tsconfig/base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@c3/ui": ["../../packages/ui/src/index.ts"],
      "@c3/ui/*": ["../../packages/ui/src/*"],
      "@c3/config": ["../../packages/config/src/index.ts"],
      "@c3/config/*": ["../../packages/config/src/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
